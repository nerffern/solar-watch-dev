# SolarWatch — .env
# Copy to /opt/solarwatch/.env and fill in real values.
# Never commit this file to git — it's in .gitignore.

# PostgreSQL
PG_HOST=postgres-ha.hfisystems.com
PG_PORT=5432
PG_DB=solarwatch
PG_USER=solarwatch_user
PG_PASS=CHANGEME
PG_SSLMODE=prefer

# Collector behaviour
POLL_INTERVAL=60      # seconds between poll cycles
MAX_RETRIES=3         # per inverter per cycle
RETRY_DELAY=5         # seconds between retries
CONFIG_RELOAD=300     # re-read sites table every N seconds
